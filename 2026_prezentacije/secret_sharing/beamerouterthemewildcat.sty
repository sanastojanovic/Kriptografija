% Footer (Pages)
%% NOTE: ON OVERLEAF USE ht=-2.5ex. Not sure why this is needed.
\setbeamertemplate{footline}{
  \ifbeamer@inappendix\else
    \ifnum\insertframenumber>1
      \def\wc@tmp{none}\ifx\wc@numbering\wc@tmp\else
        \def\wc@tmp{progressbar}\ifx\wc@numbering\wc@tmp
          \ifnum\insertmainframenumber>1
            \begingroup
              \dimen@=\paperwidth
              \multiply\dimen@ by \numexpr\insertframenumber-1\relax
              \divide\dimen@ by \numexpr\insertmainframenumber-1\relax
              \leavevmode
              \rlap{\color{wcprimary!10}\rule{\paperwidth}{1.8pt}}%
              {\color{wcprimary}\rule{\dimen@}{1.8pt}}%
            \endgroup
          \fi
        \else
          \begin{beamercolorbox}[wd=\paperwidth,ht=-2.5ex,dp=1.125ex,right]{page number in head/foot}
            \usebeamerfont{page number in head/foot}%
            \color{black!20}%
            \def\wc@tmp{number}\ifx\wc@numbering\wc@tmp
              \the\numexpr\insertframenumber-1\relax
            \else
              \ifnum\insertmainframenumber>1
                \the\numexpr\insertframenumber-1\relax/\the\numexpr\insertmainframenumber-1\relax
              \fi
            \fi
            \hspace{1em}
          \end{beamercolorbox}
        \fi
      \fi
    \fi
  \fi
}

\makeatother

\mode<all>
